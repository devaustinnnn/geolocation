# Free Census Data API key — sign up (instant) at:
#   https://api.census.gov/data/key_signup.html
# The ACS population step REQUIRES this key. Geocoding and TIGERweb do not.
CENSUS_API_KEY=

# Port the API server listens on
PORT=5000

# Census vintages (override only if you know what you're doing)
ACS_YEAR=2024
TIGERWEB_SERVICE=tigerWMS_ACS2024

# --- Parcel database (PostgreSQL / PostGIS) ---
# Leave DATABASE_URL empty to use the built-in sample parcel.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=
DB_SSL=false
# Table holding parcels, and the column names within it (use EXACT case).
PARCEL_TABLE=parcels
PARCEL_ID_COL=parcel_number
PARCEL_ADDR_COL=address
PARCEL_LAT_COL=latitude
PARCEL_LNG_COL=longitude
# Optional — leave empty if you don't have a county column
PARCEL_COUNTY_COL=
# Optional — PostGIS geometry column for the parcel boundary polygon
PARCEL_GEOM_COL=
